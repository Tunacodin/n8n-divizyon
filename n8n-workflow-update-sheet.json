{
  "name": "Dashboard → Google Sheets Update",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "update-sheet",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [250, 300]
    },
    {
      "parameters": {
        "operation": "update",
        "documentId": {
          "__rl": true,
          "mode": "id",
          "value": "={{ $json.body.sheetId }}"
        },
        "sheetName": {
          "__rl": true,
          "mode": "name",
          "value": "={{ $json.body.sheet === 'kontrol' ? 'Kontrol' : $json.body.sheet === 'kesinRet' ? 'Kesin Ret' : $json.body.sheet === 'kesinKabul' ? 'Kesin Kabul' : 'Nihai Olmayan Ağ Üyeleri' }}"
        },
        "columns": {
          "mappingMode": "autoMapInputData",
          "value": {}
        },
        "options": {
          "cellFormat": "USER_ENTERED"
        }
      },
      "id": "sheets-update",
      "name": "Google Sheets - Update",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [700, 300],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "GOOGLE_CREDENTIAL_ID",
          "name": "Google Sheets account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Webhook'tan gelen veriyi Google Sheets update formatına çevir\nconst body = $input.first().json.body;\nconst email = body.email;\nconst updates = body.updates;\n\n// Google Sheets node için output: E-Posta Adresin (match column) + güncellenen alanlar\nconst output = {\n  'E-Posta Adresin': email,\n  ...updates\n};\n\nreturn [{ json: output }];"
      },
      "id": "code-transform",
      "name": "Transform Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [470, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ success: true, updated: Object.keys($('Transform Data').first().json).filter(k => k !== 'E-Posta Adresin') }) }}"
      },
      "id": "response-node",
      "name": "Respond to Webhook",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [920, 300]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "Transform Data",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Transform Data": {
      "main": [
        [
          {
            "node": "Google Sheets - Update",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Google Sheets - Update": {
      "main": [
        [
          {
            "node": "Respond to Webhook",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "meta": {
    "templateCredsSetupCompleted": true
  }
}
